    {
      "id": "scene-4c",
      "source": "",
      "in_seconds": 333.933,
      "out_seconds": 357.833,
      "type": "terminal_scene",
      "terminalTitle": "python-frontmatter 最小编排器",
      "prompt": "$",
      "steps": [
        {
          "kind": "out",
          "text": "import frontmatter, glob"
        },
        {
          "kind": "out",
          "text": ""
        },
        {
          "kind": "out",
          "text": "for path in glob.glob(\"content-library/**/README.md\", recursive=True):"
        },
        {
          "kind": "out",
          "text": "    post = frontmatter.load(path)"
        },
        {
          "kind": "out",
          "text": "    if post.get(\"status\") == \"approved\":"
        },
        {
          "kind": "out",
          "text": "        stage = post[\"stage\"]"
        },
        {
          "kind": "out",
          "text": "        role  = load_role(stage)       # 角色 = system_prompt"
        },
        {
          "kind": "out",
          "text": "        steps = load_workflow(stage)   # 工作流 = user_prompt"
        },
        {
          "kind": "out",
          "text": "        run_agent(system=role, user=steps)"
        }
      ]
    },
